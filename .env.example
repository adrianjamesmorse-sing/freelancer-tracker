# API base path (Azure Static Web Apps serves linked functions at /api)
VITE_API_BASE_URL=/api

# Optional build-time Entra settings for MSAL.
# If omitted, the app loads tenant/client IDs from GET /api/auth/config
# (set ENTRA_TENANT_ID and ENTRA_CLIENT_ID in Azure SWA → Configuration).
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_ALLOWED_DOMAIN=singulier.co
VITE_ENTRA_REDIRECT_URI=http://localhost:5173/login

# Local UI without Entra
# VITE_AUTH_DISABLED=true
